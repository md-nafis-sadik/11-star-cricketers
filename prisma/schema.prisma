generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PLAYER
}

enum MatchStatus {
  UPCOMING
  LIVE
  COMPLETED
  CANCELLED
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  INJURED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SessionType {
  MATCH
  PRACTICE
  MEETING
}

model User {
  id               String          @id @default(cuid())
  clerkId          String          @unique
  email            String          @unique
  name             String
  imageUrl         String?
  role             UserRole        @default(PLAYER)
  publicMetadata   Json?
  playerProfile    PlayerProfile?
  announcements    Announcement[]  @relation("AnnouncementAuthor")
  notifications    Notification[]
  galleryUploads   GalleryImage[]   @relation("GalleryUploader")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([role])
}

model Team {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  city            String?
  foundedYear     Int?
  players         PlayerProfile[]
  matches         Match[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([slug])
}

model PlayerProfile {
  id                 String           @id @default(cuid())
  userId             String?          @unique
  teamId             String?
  fullName           String
  jerseyNumber       Int              @unique
  battingStyle       String
  bowlingStyle       String
  role               String
  availability       AvailabilityStatus @default(AVAILABLE)
  city               String
  imageUrl           String?
  bio                String?
  user               User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  team               Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull)
  battingStats       BattingStats[]
  bowlingStats       BowlingStats[]
  attendanceRecords  Attendance[]
  availabilityRecord Availability?
  playingXIMembers   PlayingXIMember[]

  @@index([teamId])
  @@index([availability])
  @@index([role])
}

model Match {
  id              String        @id @default(cuid())
  teamId          String?
  title           String
  opponent        String
  venue           String
  startTime       DateTime
  format          String
  status          MatchStatus   @default(UPCOMING)
  tossResult      String?
  matchResult     String?
  liveScore       String?
  team            Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull)
  scorecard       Scorecard?
  attendance      Attendance[]
  playingXI       PlayingXI?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([startTime])
  @@index([teamId])
}

model Scorecard {
  id                    String    @id @default(cuid())
  matchId               String    @unique
  teamRuns              Int       @default(0)
  wickets               Int       @default(0)
  overs                 Float     @default(0)
  extras                Int       @default(0)
  target                Int?
  resultSummary         String?
  battingEntries        BattingStats[]
  bowlingEntries        BowlingStats[]
  match                 Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model BattingStats {
  id                String         @id @default(cuid())
  playerProfileId   String
  scorecardId       String?
  runs              Int            @default(0)
  balls             Int            @default(0)
  fours             Int            @default(0)
  sixes             Int            @default(0)
  strikeRate        Float          @default(0)
  playerProfile     PlayerProfile   @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  scorecard         Scorecard?     @relation(fields: [scorecardId], references: [id], onDelete: SetNull)

  @@index([playerProfileId])
  @@index([scorecardId])
}

model BowlingStats {
  id                String         @id @default(cuid())
  playerProfileId   String
  scorecardId       String?
  wickets           Int            @default(0)
  overs             Float          @default(0)
  runsConceded      Int            @default(0)
  maidens           Int            @default(0)
  economy           Float          @default(0)
  playerProfile     PlayerProfile   @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  scorecard         Scorecard?     @relation(fields: [scorecardId], references: [id], onDelete: SetNull)

  @@index([playerProfileId])
  @@index([scorecardId])
}

model Attendance {
  id               String         @id @default(cuid())
  playerProfileId  String
  matchId          String?
  sessionType      SessionType
  status           AvailabilityStatus
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  lateByMinutes    Int            @default(0)
  note             String?
  playerProfile    PlayerProfile   @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  match            Match?         @relation(fields: [matchId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([playerProfileId])
  @@index([matchId])
  @@index([status])
}

model Announcement {
  id              String               @id @default(cuid())
  title           String
  body            String
  priority        AnnouncementPriority @default(NORMAL)
  publishedAt     DateTime             @default(now())
  authorId        String?
  author          User?                @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([priority])
  @@index([publishedAt])
}

model Notification {
  id              String    @id @default(cuid())
  userId          String
  title           String
  body            String
  type            String
  readAt          DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([readAt])
}

model GalleryImage {
  id              String   @id @default(cuid())
  title           String
  category        String
  imageUrl        String
  uploadedById    String?
  uploadedBy      User?    @relation("GalleryUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([uploadedById])
}

model Availability {
  id               String             @id @default(cuid())
  playerProfileId  String             @unique
  status           AvailabilityStatus @default(AVAILABLE)
  note             String?
  updatedAt        DateTime           @updatedAt
  playerProfile    PlayerProfile      @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([status])
}

model PlayingXI {
  id               String            @id @default(cuid())
  matchId          String            @unique
  captainId        String
  viceCaptainId    String
  match            Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  members          PlayingXIMember[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([matchId])
}

model PlayingXIMember {
  id               String          @id @default(cuid())
  playingXiId      String
  playerProfileId  String
  battingPosition  Int?
  isCaptain        Boolean         @default(false)
  isViceCaptain    Boolean         @default(false)
  playingXI        PlayingXI       @relation(fields: [playingXiId], references: [id], onDelete: Cascade)
  playerProfile    PlayerProfile   @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@unique([playingXiId, playerProfileId])
  @@index([playerProfileId])
}
